<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>OpenSource Access Portal - Console</title>
  <style>
    :root {
      --brand-deep: #0d4f68;
      --brand-main: #1f8a70;
      --brand-soft: #e8f4ef;
      --text-main: #10363f;
      --text-soft: #4f6b72;
      --panel: #ffffff;
      --line: rgba(13, 79, 104, 0.18);
      --shadow: 0 20px 45px rgba(16, 54, 63, 0.14);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Segoe UI", "Helvetica Neue", sans-serif;
      color: var(--text-main);
      background:
        radial-gradient(circle at 12% 15%, rgba(53, 168, 115, 0.20), transparent 42%),
        radial-gradient(circle at 88% 12%, rgba(13, 79, 104, 0.22), transparent 48%),
        linear-gradient(145deg, #f7fcfa 0%, #e7f1f5 100%);
      min-height: 100vh;
      padding: 22px;
    }
    .shell {
      max-width: 920px;
      margin: 0 auto;
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 20px;
      box-shadow: var(--shadow);
      padding: 24px;
    }
    .top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      border-bottom: 1px solid var(--line);
      padding-bottom: 18px;
      margin-bottom: 18px;
    }
    .brand { display: flex; align-items: center; gap: 14px; }
    .brand img { width: 58px; height: 58px; object-fit: contain; }
    .brand .name { margin: 0; font-size: 1.35rem; font-weight: 700; }
    .brand .tag { margin: 3px 0 0; color: var(--text-soft); }
    h1 { margin: 0 0 8px; font-size: 1.38rem; }
    .sub { margin: 0 0 12px; color: var(--text-soft); }
    .panel {
      border: 1px solid var(--line);
      background: linear-gradient(180deg, #fcfefe, #f7fbfc);
      border-radius: 14px;
      padding: 14px;
      margin-top: 12px;
    }
    .panel h2 { margin: 0 0 6px; font-size: 1.12rem; }
    pre {
      background: #f2f8f8;
      border: 1px solid rgba(13, 79, 104, 0.2);
      border-radius: 10px;
      padding: 10px;
      overflow-x: auto;
      margin: 8px 0 0;
    }
    code { color: var(--brand-deep); }
    .logout {
      border: 0;
      border-radius: 10px;
      background: linear-gradient(135deg, var(--brand-main), var(--brand-deep));
      color: #fff;
      padding: 10px 14px;
      font-weight: 700;
      cursor: pointer;
    }
    .logout:hover { filter: brightness(1.04); }
  </style>
</head>
<body>
  <main class="shell">
    <header class="top">
      <div class="brand">
        <img src="https://epos-eric.github.io/opensource-docs/img/logo-opensource-1-light.png" alt="Open Source logo">
        <div>
          <p class="name">OpenSource Access Portal</p>
          <p class="tag">Identity and OAuth operations console</p>
        </div>
      </div>
      <form method="post" action="/logout">
        <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
        <button class="logout" type="submit">Logout</button>
      </form>
    </header>

    <h1>Welcome {{.User.Name}} {{.User.Surname}}</h1>
    <p class="sub">You are logged in as <strong>{{.User.Email}}</strong>.</p>

    <section class="panel">
      <h2>OAuth2 API</h2>
      <p>Demo OAuth client: <code>local-dev-client</code> / <code>dev-secret</code></p>
      <p>Generate access and refresh tokens:</p>
      <pre>curl -X POST http://localhost:8080/oauth/token \
  -u local-dev-client:dev-secret \
  -d "grant_type=password" \
  -d "username={{.User.Email}}" \
  -d "password=YOUR_PASSWORD"</pre>

      <p>Validate a bearer token:</p>
      <pre>curl -H "Authorization: Bearer ACCESS_TOKEN" http://localhost:8080/oauth/validate</pre>

      <p>Call a protected endpoint:</p>
      <pre>curl -H "Authorization: Bearer ACCESS_TOKEN" http://localhost:8080/api/me</pre>
    </section>
  </main>
</body>
</html>
